{
  "name": "@switchbot/openclaw-channel",
  "version": "0.1.0",
  "description": "SwitchBot channel plugin for OpenClaw — real-time device status via AWS IoT Core",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "prepare": "npm run build",
    "dev": "tsc --watch"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "channel": {
      "id": "switchbot",
      "label": "SwitchBot",
      "selectionLabel": "SwitchBot (Smart Home)",
      "blurb": "Real-time SwitchBot device status via AWS IoT Core MQTT",
      "order": 85
    }
  },
  "dependencies": {
    "mqtt": "5.10.3",
    "zod": "3.24.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^18.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "switchbot",
    "iot",
    "mqtt",
    "smart-home"
  ],
  "author": "SwitchBot Team",
  "license": "MIT",
  "files": [
    "dist/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bug-monster/openclaw-extensions.git"
  }
}